        "summary": "Create a dependency edge between two nodes (intra- or cross-plan)",
        "tags": [
          "v1"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "201": {
            "description": "Dependency created"
          },
          "409": {
            "description": "Edge would create a cycle"
          }
        }
      }
    },
    "/v1/dependencies/{id}": {
      "delete": {
        "summary": "Remove a dependency edge",
        "tags": [
          "v1"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Dependency removed"
          },
          "404": {
            "description": "Dependency not found"
          }
        }
      }
    },
