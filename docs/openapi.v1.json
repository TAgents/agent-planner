        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Pending decisions",
            "agent requests": null,
            "and drafts": null
          }
        }
      }
    },
    "/v1/decisions/{id}/resolve": {
      "post": {
        "summary": "Resolve a decision (approve/defer/reject, materialize subtasks)",
        "tags": [
          "v1"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Decision resolved"
          },
          "404": {
            "description": "Decision not found"
          }
        }
      }
    },
    "/v1/decisions/{id}/cancel": {
      "post": {
        "summary": "Cancel a pending decision",
        "tags": [
          "v1"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Decision cancelled"
          },
          "404": {
            "description": "Decision not found"
          }
        }
      }
    },
    "/v1/dependencies": {
