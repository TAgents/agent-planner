# AgentPlanner v2 — Production Environment Variables
# Copy to .env.production and fill in all values

# ─── Domain ──────────────────────────────────────────────────
DOMAIN=planner.example.com

# Base URLs (used for link generation in Slack messages and OAuth callbacks)
APP_URL=https://planner.example.com          # frontend base — used for plan/task links in Slack
API_BASE_URL=https://planner.example.com/api # API base — used for Slack OAuth callback URL

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=agentplanner
POSTGRES_PASSWORD=          # REQUIRED: strong random password
POSTGRES_DB=agentplanner

# ─── API Server ─────────────────────────────────────────────
JWT_SECRET=                 # REQUIRED: openssl rand -hex 32
OPENAI_API_KEY=             # REQUIRED: OpenAI API key

# ─── Graphiti Knowledge Graph ─────────────────────────────
# Internal Docker URL — no external access needed
GRAPHITI_INTERNAL_URL=http://graphiti:8000

# ─── Optional AI Features ───────────────────────────────────
ANTHROPIC_API_KEY=          # For AI reasoning features

# ─── Slack Integration (optional) ───────────────────────────
# Create a Slack app at https://api.slack.com/apps
# OAuth scopes needed: chat:write, channels:read, groups:read
# Redirect URL to set in Slack app: ${API_BASE_URL}/integrations/slack/callback
SLACK_CLIENT_ID=            # from Slack app → Basic Information → App Credentials
SLACK_CLIENT_SECRET=        # from Slack app → Basic Information → App Credentials
SLACK_ENCRYPTION_KEY=       # openssl rand -hex 32 (encrypts stored user tokens)

# ─── Other Messaging (optional) ──────────────────────────────
DISCORD_TOKEN=

# ─── Backup (optional) ──────────────────────────────────────
# Leave empty to keep backups locally (30-day retention in Docker volume)
GCS_BACKUP_BUCKET=          # e.g. agentplanner-backups
