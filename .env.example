# ─── Database ─────────────────────────────────────────────────────
# Docker Compose uses these for the postgres container AND the app:
POSTGRES_USER=agentplanner
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=agentplanner
POSTGRES_PORT=5433

# Direct connection string (used by app when running outside Docker):
DATABASE_URL=postgresql://agentplanner:devpassword@127.0.0.1:5433/agentplanner

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production

# ─── Legacy (Supabase — will be removed in v2) ──────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Application ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
API_PORT=3000

# ─── Graphiti Knowledge Graph (optional) ─────────────────────────
# Graphiti + Neo4j run as internal Docker services.
# Set this to connect the API to the Graphiti knowledge graph.
GRAPHITI_INTERNAL_URL=http://graphiti:8000
OPENAI_API_KEY=

# Neo4j (knowledge graph backend for Graphiti)
NEO4J_PASSWORD=devpassword

# ─── Optional ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Slack Integration (optional) ────────────────────────────────
# See docs/SLACK_INTEGRATION.md for setup steps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_ENCRYPTION_KEY=           # falls back to JWT_SECRET in dev; set explicitly in production
APP_URL=http://localhost:3001   # base URL for plan/task links in Slack messages
API_BASE_URL=http://localhost:3000  # base URL for Slack OAuth callback
